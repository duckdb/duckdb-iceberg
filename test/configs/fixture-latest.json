{
	"description": "Use apache/iceberg-rest-fixture:latest as Iceberg REST Catalog.",
	"on_init": "CREATE SECRET (TYPE S3,KEY_ID 'admin',SECRET 'password',ENDPOINT '127.0.0.1:9000',URL_STYLE 'path',USE_SSL 0); ATTACH '' AS my_datalake (TYPE ICEBERG,CLIENT_ID 'admin',CLIENT_SECRET 'password',ENDPOINT 'http://127.0.0.1:8181'); Create schema if not exists my_datalake.default; set iceberg_use_server_side_scan_planning=true;",
	"statically_loaded_extensions": [
		"core_functions",
		"parquet",
		"avro",
		"iceberg",
		"httpfs",
		"icu"
	],
	"test_env": [
		{
			"env_name": "CATALOG_TEST_CONFIG_SETUP",
			"env_value": "fixture"
		}
	],
	"skip_tests": [
		{
			"reason": "Server-side planning doesn't provide us with pruning-related logs",
			"paths": [
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/delete/test_no_head_request_for_deletes.test",
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/combined/test_identity_and_year.test",
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/large/test_large_multiple_inserts.test",
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/multi_insert/test_manifest_skip_combined_transforms.test",
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/multi_insert/test_manifest_skip_year_transform.test",
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/multi_insert/test_multiple_inserts_manifest_list_skip.test",
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/partitions/test_insert_into_partitioned_table_month.test",
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/logging/test_reads_on_bounds.test"
			]
		},
		{
			"reason": "Disabled due to bugs in the iceberg-rest-fixture scan-planning implementation",
			"paths": [
				"test/sql/local/catalog_test_config_setup/catalog_agnostic/insert/test_insert_to_v3_tables.test"
			]
		}
	]
}