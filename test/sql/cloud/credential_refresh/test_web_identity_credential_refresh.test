# name: test/sql/cloud/credential_refresh/test_web_identity_credential_refresh.test
# description: Test that web_identity credential chain stores refresh_info for auto-refresh
# group: [credential_refresh]
#
# This test validates that when using PROVIDER credential_chain with CHAIN 'web_identity',
# the AWS secret stores refresh_info which enables automatic credential refresh for both:
# 1. SigV4 catalog API calls (via TryRefreshStorageSecret in sigv4.cpp)
# 2. S3 data reads (via httpfs refresh on 403/ExpiredToken)
#
# Environment setup required:
# - AWS_ROLE_ARN: ARN of the IAM role to assume
# - AWS_WEB_IDENTITY_TOKEN_FILE: Path to the web identity token file (e.g., IRSA on EKS)
# - AWS_ROLE_SESSION_NAME: (optional) session name
# - An Iceberg REST catalog accessible via SigV4 with the assumed role
#
# On EKS with IRSA, these are automatically mounted by the service account.
# For local testing, use the MinIO-based OIDC test harness from duckdb-aws PR #136.

mode skip

require avro

require parquet

require iceberg

require httpfs

require aws

# Verify that web_identity chain creates a secret with refresh_info
statement ok
CREATE SECRET aws_test_secret (
    TYPE S3,
    PROVIDER credential_chain,
    CHAIN 'web_identity',
    REGION 'us-west-2'
);

# The secret should exist and have the credential_chain provider
query III
SELECT name, type, provider FROM duckdb_secrets() WHERE name = 'aws_test_secret';
----
aws_test_secret	s3	credential_chain

# Clean up
statement ok
DROP SECRET aws_test_secret;

# Test that credentials work for an Iceberg REST catalog with SigV4 auth.
# This requires:
# - ICEBERG_TEST_ENDPOINT: The REST catalog endpoint (e.g., https://irc-01.example.com)
# - ICEBERG_TEST_WAREHOUSE: The warehouse name (e.g., 'warehouse')
# - ICEBERG_TEST_SECRET: An Iceberg secret for catalog auth

require-env ICEBERG_TEST_ENDPOINT

require-env ICEBERG_TEST_WAREHOUSE

statement ok
CREATE SECRET aws_cred_refresh_secret (
    TYPE S3,
    PROVIDER credential_chain,
    CHAIN 'web_identity',
    REGION 'us-west-2'
);

# Attach the catalog — this exercises the SigV4 credential path in sigv4.cpp
# where TryRefreshStorageSecret checks for refresh_info before signing requests
statement ok
ATTACH '${ICEBERG_TEST_WAREHOUSE}' AS test_catalog (
    TYPE iceberg,
    AUTHORIZATION_TYPE sigv4,
    ENDPOINT '${ICEBERG_TEST_ENDPOINT}'
);

# A simple catalog query validates that credentials are working
statement ok
SHOW DATABASES;

# Detach
statement ok
DETACH test_catalog;

# Clean up
statement ok
DROP SECRET aws_cred_refresh_secret;
