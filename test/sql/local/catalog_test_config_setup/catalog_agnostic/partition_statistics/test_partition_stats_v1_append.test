# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/partition_statistics/test_partition_stats_v1_append.test
# description: verify iceberg_table_partition_stats on the Spark v1 append partition statistics table
# group: [partition_statistics]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set variable v1_append_latest_snapshot = (
    select snapshot_id
    from iceberg_snapshots(my_datalake.default.partition_stats_v1_append)
    order by timestamp_ms desc
    limit 1
);

query I
select typeof(partition)
from iceberg_table_partition_stats('my_datalake.default.partition_stats_v1_append')
limit 1;
----
VARCHAR

query TIIIIIIIII
select
    partition,
    spec_id,
    data_record_count,
    data_file_count,
    total_data_file_size_in_bytes,
    position_delete_record_count,
    position_delete_file_count,
    equality_delete_record_count,
    equality_delete_file_count,
    total_record_count
from iceberg_table_partition_stats('my_datalake.default.partition_stats_v1_append')
where statistics_snapshot_id = getvariable('v1_append_latest_snapshot')
order by all;
----
{'region': NULL}	0	2	2	2236	0	0	0	0	NULL
{'region': apac}	0	1	1	1165	0	0	0	0	NULL
{'region': eu}	0	2	1	1238	0	0	0	0	NULL
{'region': us}	0	2	2	2288	0	0	0	0	NULL
