# name: test/sql/local/irc_any_catalog/functions/test_iceberg_truncate.test
# description: Test iceberg_truncate scalar function against Iceberg spec
# group: [functions]

# Spec: https://iceberg.apache.org/spec/#truncate-transform-details

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- NULL handling ----
# Iceberg spec: all transforms return null for null input

query I
SELECT iceberg_truncate(NULL::INTEGER, 10);
----
NULL

query I
SELECT iceberg_truncate(NULL::BIGINT, 10);
----
NULL

query I
SELECT iceberg_truncate(NULL::VARCHAR, 5);
----
NULL

query I
SELECT iceberg_truncate(NULL::BLOB, 5);
----
NULL

# ---- Return types ----

query I
SELECT typeof(iceberg_truncate(1::INTEGER, 10));
----
INTEGER

query I
SELECT typeof(iceberg_truncate(1::BIGINT, 10));
----
BIGINT

query I
SELECT typeof(iceberg_truncate('hello', 3));
----
VARCHAR

query I
SELECT typeof(iceberg_truncate('\x01\x02\x03'::BLOB, 2));
----
BLOB

# ---- INTEGER: v - (((v % W) + W) % W) ----
# truncate[10](0) = 0
query I
SELECT iceberg_truncate(0::INTEGER, 10);
----
0

# truncate[10](1) = 0
query I
SELECT iceberg_truncate(1::INTEGER, 10);
----
0

# truncate[10](9) = 0
query I
SELECT iceberg_truncate(9::INTEGER, 10);
----
0

# truncate[10](10) = 10
query I
SELECT iceberg_truncate(10::INTEGER, 10);
----
10

# truncate[10](11) = 10
query I
SELECT iceberg_truncate(11::INTEGER, 10);
----
10

# truncate[10](-1) = -10  (floor toward negative infinity)
query I
SELECT iceberg_truncate(-1::INTEGER, 10);
----
-10

# truncate[10](-10) = -10
query I
SELECT iceberg_truncate(-10::INTEGER, 10);
----
-10

# truncate[10](-11) = -20
query I
SELECT iceberg_truncate(-11::INTEGER, 10);
----
-20

# ---- BIGINT ----

query I
SELECT iceberg_truncate(0::BIGINT, 10);
----
0

query I
SELECT iceberg_truncate(11::BIGINT, 10);
----
10

query I
SELECT iceberg_truncate(-1::BIGINT, 10);
----
-10

# ---- VARCHAR: first L grapheme clusters ----
# truncate[3]("iceberg") = "ice"
query I
SELECT iceberg_truncate('iceberg', 3);
----
ice

# truncate[7]("iceberg") = "iceberg" (width >= length, return as-is)
query I
SELECT iceberg_truncate('iceberg', 7);
----
iceberg

# truncate[10]("iceberg") = "iceberg" (width > length)
query I
SELECT iceberg_truncate('iceberg', 10);
----
iceberg

# Empty string stays empty
query I
SELECT iceberg_truncate('', 5);
----
(empty)

# ---- BLOB: first L bytes ----

query I
SELECT iceberg_truncate('\x01\x02\x03\x04'::BLOB, 2);
----
\x01\x02

# Width >= length returns the full blob
query I
SELECT iceberg_truncate('\x01\x02'::BLOB, 10);
----
\x01\x02

# ---- Result is always a multiple of W for integers ----

query I
SELECT bool_and(iceberg_truncate(range::INTEGER, 10) % 10 = 0)
FROM range(-100, 100);
----
true

query I
SELECT bool_and(iceberg_truncate(range::INTEGER, 7) % 7 = 0)
FROM range(-100, 100);
----
true

# ---- Result is <= input for non-negative integers ----

query I
SELECT bool_and(iceberg_truncate(range::INTEGER, 10) <= range)
FROM range(0, 100);
----
true

# ---- Width = 0 is invalid (Iceberg spec requires positive width) ----

statement error
SELECT iceberg_truncate(1::INTEGER, 0);
----
<REGEX>:.*width must be a positive integer.*

statement error
SELECT iceberg_truncate(1::BIGINT, 0);
----
<REGEX>:.*width must be a positive integer.*

statement error
SELECT iceberg_truncate('iceberg', 0);
----
<REGEX>:.*width must be a positive integer.*

statement error
SELECT iceberg_truncate('\x01\x02'::BLOB, 0);
----
<REGEX>:.*width must be a positive integer.*