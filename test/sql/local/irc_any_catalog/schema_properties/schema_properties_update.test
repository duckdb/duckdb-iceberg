# name: test/sql/local/irc_any_catalog/schema_properties/schema_properties_update.test
# group: [schema_properties]

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;


statement ok
SET ca_cert_file = '~/.mitmproxy/mitmproxy-ca-cert.pem';

statement ok
CREATE SECRET http_proxy (
    TYPE http,
    HTTP_PROXY 'http://localhost:8878'
);

query II
CALL iceberg_schema_properties(my_datalake.default);
----
location	s3://warehouse/default

query I
CALL set_iceberg_schema_properties(my_datalake.default,
    {
    'myprop1' : '1',
    'myprop2' : '2',
    'myprop3' : '3',
    }
);
----
3

query II
CALL iceberg_schema_properties(my_datalake.default);
----
myprop2	2
myprop3	3
myprop1	1
location	s3://warehouse/default

query I
CALL remove_iceberg_schema_properties(my_datalake.default, ['myprop2']);
----
0

query II
CALL iceberg_schema_properties(my_datalake.default);
----
myprop3	3
myprop1	1
location	s3://warehouse/default

query I
CALL remove_iceberg_schema_properties(my_datalake.default, ['non_exisiting_prop']);
----
0
