# name: test/sql/local/irc_any_catalog/partitioning/partitioned_write_row-group-size-bytes.test
# group: [partitioning]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

statement ok
CALL enable_logging(level='warning');

statement ok
drop table if exists my_datalake.default.my_table;

statement ok
CREATE TABLE my_datalake.default.my_table (
  user_id INT
) PARTITIONED BY (user_id) WITH (
  'write.parquet.row-group-size-bytes' = '134217728'
);

query II
SELECT log_level, message FROM duckdb_logs
----

statement error
INSERT INTO my_datalake.default.my_table SELECT * FROM range(1000);
----
Binder Error: ROW_GROUP_SIZE_BYTES does not work while preserving insertion order. Use "SET preserve_insertion_order=false;" to disable preserving insertion order.

statement ok
SET preserve_insertion_order=false;

statement ok
INSERT INTO my_datalake.default.my_table SELECT * FROM range(1000);

query II
SELECT log_level, message FROM duckdb_logs
----
WARNING	Property row_group_size_bytes is currently only supported for unpartitioned writes
WARNING	Property row_group_size_bytes is currently only supported for unpartitioned writes