WARNING	Property target-file-size-bytes is currently only supported for unpartitioned writes

statement ok
set variable my_manifest = (select manifest_path from iceberg_metadata(my_datalake.default.my_table) limit 1);

# TODO: Fix this once partitioned writes with target-file-size-bytes are fully supported
query I
select file_size_in_bytes from (select unnest(data_file) from read_avro(getvariable('my_manifest'))) LIMIT 5;
