statement ok
CALL enable_logging(level='warning');

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.my_table;

statement ok
CREATE TABLE my_datalake.default.my_table (
  user_id INT
) PARTITIONED BY (user_id) WITH (
  'write.target-file-size-bytes' = '200'
);

query II
SELECT log_level, message FROM duckdb_logs
