# name: test/sql/local/irc_any_catalog/partitioning/partitioned_write_target-file-size-bytes_memory_specified.test
# group: [partitioning]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

statement ok
drop table if exists my_datalake.default.my_table;

statement ok
CREATE TABLE my_datalake.default.my_table (
  user_id INT
) PARTITIONED BY (user_id) WITH (
  'write.target-file-size-bytes' = '200KB'
);

statement error
INSERT INTO my_datalake.default.my_table SELECT * FROM range(100);
----
Invalid Input Error: Table property target-file-size-bytes is currently not supported for partitioned tables. This property is being ignored.
To ignore this error run "SET ignore_target_file_size_bytes_for_partitioned_tables=true"

statement ok
SET ignore_target_file_size_bytes_for_partitioned_tables=true

statement ok
INSERT INTO my_datalake.default.my_table SELECT * FROM range(100);