# name: test/sql/local/irc_any_catalog/alter/set_not_null/alter_set_not_null_added_column_with_null_default.test
# group: [set_not_null]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.my_table;

# creates a snapshot
statement ok
CREATE TABLE my_datalake.default.my_table WITH ('format-version'='3') AS (select range a FROM range(10));

# doesn't create a snapshot
statement ok
ALTER TABLE my_datalake.default.my_table ADD COLUMN b int DEFAULT NULL;

query II
FROM my_datalake.default.my_table;
----
0	NULL
1	NULL
2	NULL
3	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL

statement ok
ALTER TABLE my_datalake.default.my_table ALTER COLUMN b SET NOT NULL;

statement error
INSERT INTO my_datalake.default.my_table VALUES (NULL, NULL);
----
Constraint Error: NOT NULL constraint failed: my_table.b

query II
FROM my_datalake.default.my_table;
----
0	NULL
1	NULL
2	NULL
3	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL