# name: test/sql/local/irc_any_catalog/alter/set_not_null/alter_set_not_null_with_delete_one_by_one.test
# group: [set_not_null]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.my_table;

statement ok
CREATE TABLE my_datalake.default.my_table WITH ('format-version'='3') AS (select range a FROM range(10));

statement ok
ALTER TABLE my_datalake.default.my_table ADD COLUMN b int DEFAULT 42;

statement ok
INSERT INTO my_datalake.default.my_table VALUES (10, NULL);

statement ok
INSERT INTO my_datalake.default.my_table VALUES (11, NULL);

query II
FROM my_datalake.default.my_table ORDER BY ALL;
----
0	42
1	42
2	42
3	42
4	42
5	42
6	42
7	42
8	42
9	42
10	NULL
11	NULL

statement ok
DELETE FROM my_datalake.default.my_table WHERE a=10;

query II
FROM my_datalake.default.my_table ORDER BY ALL;
----
0	42
1	42
2	42
3	42
4	42
5	42
6	42
7	42
8	42
9	42
11	NULL

statement error
ALTER TABLE my_datalake.default.my_table ALTER COLUMN b SET NOT NULL;
----
Constraint Error: NOT NULL constraint failed: my_table.b

statement ok
DELETE FROM my_datalake.default.my_table WHERE a=11;

statement ok
ALTER TABLE my_datalake.default.my_table ALTER COLUMN b SET NOT NULL;

query II
FROM my_datalake.default.my_table;
----
0	42
1	42
2	42
3	42
4	42
5	42
6	42
7	42
8	42
9	42