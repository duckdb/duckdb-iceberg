# name: test/sql/local/irc_any_catalog/alter/alter_add_column_two_transactions.test
# description: Reading an altered table inside an explicit BEGIN/COMMIT transaction (after ALTER already committed)
# group: [alter]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.alter_add_column_explicit_txn;

statement ok
CREATE TABLE my_datalake.default.alter_add_column_explicit_txn WITH ('format-version' = 2) AS (select range a FROM range(10));

statement ok con1
BEGIN;

statement ok con2
BEGIN;

statement ok con1
ALTER TABLE my_datalake.default.alter_add_column_explicit_txn ADD COLUMN b int;

query II con1
FROM my_datalake.default.alter_add_column_explicit_txn ORDER BY a;
----
0	NULL
1	NULL
2	NULL
3	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL

statement ok con1
COMMIT;

statement ok
CALL enable_logging(level='warning');

# Schema changed, ACID is violated.
query II con2
FROM my_datalake.default.alter_add_column_explicit_txn ORDER BY a;
----
0	NULL
1	NULL
2	NULL
3	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL

query II
SELECT log_level, message FROM duckdb_logs
----
WARNING	Detected schema change during transaction (schema_id mismatch); ACID guarantees may not hold.

statement ok con2
INSERT INTO my_datalake.default.alter_add_column_explicit_txn VALUES (42, 42);

query II con2
FROM my_datalake.default.alter_add_column_explicit_txn ORDER BY a;
----
0	NULL
1	NULL
2	NULL
3	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL
42	42

statement ok con2
COMMIT;