# name: test/sql/local/irc_any_catalog/alter/alter_default.test
# group: [alter]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

require ducklake

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
drop table if exists my_datalake.default.drop_default;

statement ok
begin transaction

statement ok
create table my_datalake.default.drop_default(
	a VARCHAR,
	b BOOLEAN
) WITH (
	'format-version'='3'
);

statement error
ALTER TABLE my_datalake.default.drop_default ALTER COLUMN b SET DEFAULT uuid()
----
Not implemented Error: Only foldable expressions are allowed as DEFAULT values

statement ok
abort

statement ok
begin transaction

statement ok
create table my_datalake.default.drop_default(
	a VARCHAR
) WITH (
	'format-version'='3'
);

statement ok
insert into my_datalake.default.drop_default (a) VALUES ('hello world')

statement ok
ALTER TABLE my_datalake.default.drop_default ADD COLUMN b bool DEFAULT false

query II
select * from my_datalake.default.drop_default
----
hello world	false

statement ok
ALTER TABLE my_datalake.default.drop_default ALTER COLUMN b SET DEFAULT true

statement ok
insert into my_datalake.default.drop_default (a) VALUES ('test')

query II
select * from my_datalake.default.drop_default order by all
----
hello world	false
test	true

statement ok
commit

query II
select * from my_datalake.default.drop_default order by all
----
hello world	false
test	true

# FIXME: https://github.com/duckdb/duckdb-iceberg/pull/911

# DROP DEFAULT will set the 'write-default' to NULL, which is a state that already existed on the table
statement error
ALTER TABLE my_datalake.default.drop_default ALTER COLUMN b DROP DEFAULT;
----
Not implemented Error: Attempted to add a schema that already exists in the table

statement ok
ALTER TABLE my_datalake.default.drop_default ADD COLUMN c INTEGER;

# Now it's fine, because the old state didn't have the 'c' column
statement ok
ALTER TABLE my_datalake.default.drop_default ALTER COLUMN b DROP DEFAULT;

statement ok
insert into my_datalake.default.drop_default(a) VALUES ('not null')

# By dropping the default, the 'initial-default' value gets used instead
# note that because of this, if 'initial-default' is not NULL, it's not possible to make the DEFAULT for new rows be NULL
query II
select a, b from my_datalake.default.drop_default order by all
----
hello world	false
not null	NULL
test	true
