# name: test/sql/local/irc_any_catalog/alter/rename_table/rename_table_test.test
# group: [rename_table]

# Clean up any existing tables
statement ok
drop table if exists my_datalake.default.t1;

statement ok
drop table if exists my_datalake.default.t2;

statement ok
drop table if exists my_datalake.default.t3;

# Test 1: Basic rename with commit
statement ok
create table my_datalake.default.t1(i INTEGER);

statement ok
insert into my_datalake.default.t1 values (1), (2), (3);

statement ok
begin transaction

statement ok
alter table my_datalake.default.t1 rename to t2

query I
select * from my_datalake.default.t2 order by i
----
1
2
3

statement error
select * from my_datalake.default.t1
----

statement ok
commit

query I
select * from my_datalake.default.t2 order by i
----
1
2
3

statement error
select * from my_datalake.default.t1
----

# Test 2: Rename with rollback
statement ok
begin transaction

statement ok
alter table my_datalake.default.t2 rename to t3

query I
select * from my_datalake.default.t3 order by i
----
1
2
3

statement ok
rollback

query I
select * from my_datalake.default.t2 order by i
----
1
2
3

statement error
select * from my_datalake.default.t3
----

# Test 3: Multiple renames in same transaction with commit
statement ok
begin transaction

statement ok
alter table my_datalake.default.t2 rename to t3

statement ok
alter table my_datalake.default.t3 rename to t1

statement ok
commit

query I
select * from my_datalake.default.t1 order by i
----
1
2
3

statement error
select * from my_datalake.default.t2
----

# Test 4: Rename to existing table name (should fail)
statement ok
create table my_datalake.default.t2(i INTEGER);

statement error
alter table my_datalake.default.t1 rename to t2
----

# Test 5: Rename and create table with same name in same transaction
statement ok
drop table if exists my_datalake.default.t2;

statement ok
begin transaction

statement ok
alter table my_datalake.default.t1 rename to t3

statement error
create table my_datalake.default.t1(j VARCHAR);
----
Not implemented Error: Cannot create table deleted within a transaction: my_datalake.default.t1

statement ok
commit

statement ok
begin transaction

statement ok
alter table my_datalake.default.t1 rename to t3

statement ok
commit

statement ok
begin

statement ok
create table my_datalake.default.t1(j VARCHAR);

statement ok
insert into my_datalake.default.t1 values ('new');

query I
select * from my_datalake.default.t3 order by i
----
1
2
3

query I
select * from my_datalake.default.t1
----
new

statement ok
commit

query I
select * from my_datalake.default.t3 order by i
----
1
2
3

query I
select * from my_datalake.default.t1
----
new

# Test 6: Scan, insert, rename, scan, insert, scan
statement ok
drop table if exists my_datalake.default.t1;

statement ok
drop table if exists my_datalake.default.t3;

statement ok
create table my_datalake.default.t1(i INTEGER);

statement ok
insert into my_datalake.default.t1 values (10);

query I
select * from my_datalake.default.t1
----
10

statement ok
begin transaction

statement ok
insert into my_datalake.default.t1 values (20);

query I
select * from my_datalake.default.t1 order by i
----
10
20

statement error
alter table my_datalake.default.t1 rename to t2
----
Catalog Error: This table (t1) was modified already, can't be renamed!

statement ok
commit

statement ok
begin

statement ok
alter table my_datalake.default.t1 rename to t2

query I
select * from my_datalake.default.t2 order by i
----
10
20

statement ok
insert into my_datalake.default.t2 values (30);

query I
select * from my_datalake.default.t2 order by i
----
10
20
30

statement ok
commit

query I
select * from my_datalake.default.t2 order by i
----
10
20
30

# Test 7: Two concurrent transactions - isolation
statement ok
drop table if exists my_datalake.default.t2;

statement ok
create table my_datalake.default.t1(i INTEGER);

statement ok
insert into my_datalake.default.t1 values (100);

statement ok con1
begin transaction

statement ok con2
begin transaction

statement ok con1
alter table my_datalake.default.t1 rename to t2

query I con1
select * from my_datalake.default.t2
----
100

statement error con1
select * from my_datalake.default.t1
----

query I con2
select * from my_datalake.default.t1
----
100

statement error con2
select * from my_datalake.default.t2
----

statement ok con1
commit

statement ok con2
commit

query I con1
select * from my_datalake.default.t2
----
100

query I con2
select * from my_datalake.default.t2
----
100

# Test 8: Rename after drop in same transaction
statement ok
drop table if exists my_datalake.default.t2;

statement ok
create table my_datalake.default.t1(i INTEGER);

statement ok
insert into my_datalake.default.t1 values (1), (2);

statement ok
create table my_datalake.default.t2(i VARCHAR);

statement ok
insert into my_datalake.default.t2 values ('a'), ('b');

statement ok
begin transaction

statement ok
drop table my_datalake.default.t2;

statement ok
alter table my_datalake.default.t1 rename to t2;

query I
select * from my_datalake.default.t2 order by i
----
1
2

statement ok
commit

query I
select * from my_datalake.default.t2 order by i
----
1
2

statement error
select * from my_datalake.default.t1
----
