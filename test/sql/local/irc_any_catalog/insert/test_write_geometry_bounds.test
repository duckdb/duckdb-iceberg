# name: test/sql/local/irc_any_catalog/insert/test_write_geometry_bounds.test
# description: Verify that DuckDB-iceberg writes correct Iceberg manifest stats for geometry
# group: [insert]

#              columns, and that those stats agree with what Spark writes for the same data.
#              Geometry columns must have NO lower/upper bounds (geometry has no scalar
#              min/max) but must have accurate null_value_counts.

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

require icu

require core_functions

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
SET TimeZone = 'UTC';

# ─────────────────────────────────────────────────────────────────
# Create DuckDB-written geometry table and insert sentinel rows
# that mirror the rows produced by the Spark data generator
# (scripts/data_generators/tests/spark_table_with_geometry_type).
#
# Sentinel values chosen to stress every dimension of geometry stats:
#   row 1 – Point(-180, -90)           → geo_xmin=-180,  geo_ymin=-90
#   row 2 – Point( 180,  90)           → geo_xmax= 180,  geo_ymax= 90
#   row 3 – LineString (0,0)→(100,100) → LineString geo_type; extent [0,100]
#   row 4 – PointZ(0, 0, 1000)         → PointZ geo_type;  geo_zmin=geo_zmax=1000
#   row 5 – NULL geometry              → null_value_count = 1
#
# WKB bytes verified via struct.pack('<BIdd', ...) etc.
# ─────────────────────────────────────────────────────────────────

statement ok
drop table if exists my_datalake.default.duckdb_written_geometry_bounds;

statement ok
create table my_datalake.default.duckdb_written_geometry_bounds (
    id      INTEGER,
    label   VARCHAR,
    geom    GEOMETRY
);

statement ok
insert into my_datalake.default.duckdb_written_geometry_bounds values
    (1, 'wgs84_min',
        ST_GeomFromWKB('\x010100000000000000008066C000000000008056C0'::BLOB)),
    (2, 'wgs84_max',
        ST_GeomFromWKB('\x010100000000000000008066400000000000805640'::BLOB)),
    (3, 'linestring',
        ST_GeomFromWKB('\x0102000000020000000000000000000000000000000000000000000000000059400000000000005940'::BLOB)),
    (4, 'point_z',
        ST_GeomFromWKB('\x01E9030000000000000000000000000000000000000000000000408F40'::BLOB)),
    (5, 'null_geom', NULL);

# ─────────────────────────────────────────────────────────────────
# Capture manifest paths for both tables
# ─────────────────────────────────────────────────────────────────

statement ok
set variable manifest_path_duckdb = (
    select manifest_path
    from iceberg_metadata(my_datalake.default.duckdb_written_geometry_bounds)
    order by manifest_sequence_number desc
    limit 1
);

statement ok
set variable manifest_path_spark = (
    select manifest_path
    from iceberg_metadata(my_datalake.default.spark_table_with_geometry_type)
    order by manifest_sequence_number desc
    limit 1
);

# ─────────────────────────────────────────────────────────────────
# 1. Lower/upper bounds for scalar columns (id=1, label=2).
#    nosort: DuckDB and Spark must produce identical serialised bounds.
# ─────────────────────────────────────────────────────────────────

query II nosort bounds_scalar
select lower_keys, lower_vals
from (
    select
        unnest(map_keys(lower_bounds))   lower_keys,
        unnest(map_values(lower_bounds)) lower_vals,
        unnest(map_keys(upper_bounds))   upper_keys,
        unnest(map_values(upper_bounds)) upper_vals
    from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))
)
where lower_keys in (1, 2)
order by all;

query II nosort bounds_scalar
select lower_keys, lower_vals
from (
    select
        unnest(map_keys(lower_bounds))   lower_keys,
        unnest(map_values(lower_bounds)) lower_vals,
        unnest(map_keys(upper_bounds))   upper_keys,
        unnest(map_values(upper_bounds)) upper_vals
    from (select unnest(data_file) from read_avro(getvariable('manifest_path_spark')))
)
where lower_keys in (1, 2)
order by all;

# ─────────────────────────────────────────────────────────────────
# 2. Geometry column (field id 3) MUST have an entry in lower_bounds
#    and upper_bounds in both tables.  Per Iceberg spec v3, geometry
#    bounds are packed little-endian doubles [X, Y, (Z), (M)]
#    representing the bounding-box corners.
# ─────────────────────────────────────────────────────────────────

# DuckDB: geometry present in lower_bounds (exactly one entry)
query I
select count(*) from (
    select unnest(map_keys(lower_bounds)) as field_id
    from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))
) where field_id = 3;
----
1

# DuckDB: geometry present in upper_bounds (exactly one entry)
query I
select count(*) from (
    select unnest(map_keys(upper_bounds)) as field_id
    from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))
) where field_id = 3;
----
1

# DuckDB and Spark lower/upper geometry bounds must match
# nosort: both engines should write identical bounding-box blobs for the same data
query II nosort geometry_bounds
select
    unnest(map_values(lower_bounds)) as lower_blob,
    unnest(map_values(upper_bounds)) as upper_blob
from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))
where list_contains(map_keys(lower_bounds), 3::INTEGER);

query II nosort geometry_bounds
select
    unnest(map_values(lower_bounds)) as lower_blob,
    unnest(map_values(upper_bounds)) as upper_blob
from (select unnest(data_file) from read_avro(getvariable('manifest_path_spark')))
where list_contains(map_keys(lower_bounds), 3::INTEGER);

# ─────────────────────────────────────────────────────────────────
# 3. null_value_counts: DuckDB and Spark output must match.
#    id (1) and label (2) → 0 nulls; geom (3) → 1 null.
# ─────────────────────────────────────────────────────────────────

query II nosort null_counts
select unnest(map_keys(null_value_counts))   as field_id,
       unnest(map_values(null_value_counts)) as null_count
from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))
order by all;

query II nosort null_counts
select unnest(map_keys(null_value_counts))   as field_id,
       unnest(map_values(null_value_counts)) as null_count
from (select unnest(data_file) from read_avro(getvariable('manifest_path_spark')))
order by all;

# Scalar columns have no nulls in DuckDB output
query I
select count(*) from (
    select unnest(map_keys(null_value_counts))   as field_id,
           unnest(map_values(null_value_counts)) as null_count
    from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))
) where field_id in (1, 2) and null_count != 0;
----
0

# Geometry null count = 1 in DuckDB output
query II
select unnest(map_keys(null_value_counts))   as field_id,
       unnest(map_values(null_value_counts)) as null_count
from (select unnest(data_file) from read_avro(getvariable('manifest_path_duckdb')))
where list_contains(map_keys(null_value_counts), 3::INTEGER)
order by field_id;
----
3	1

# Geometry null count = 1 in Spark output
query II
select unnest(map_keys(null_value_counts))   as field_id,
       unnest(map_values(null_value_counts)) as null_count
from (select unnest(data_file) from read_avro(getvariable('manifest_path_spark')))
where list_contains(map_keys(null_value_counts), 3::INTEGER)
order by field_id;
----
3	1

# ─────────────────────────────────────────────────────────────────
# 4. iceberg_column_stats(): geometry column bounds are the bounding-box
#    corners (decoded as null GEOMETRY since they are not scalar values).
#    Both DuckDB-written and Spark-written tables should agree.
# ─────────────────────────────────────────────────────────────────

query II nosort geo_col_stats
select column_name, column_type
from iceberg_column_stats(my_datalake.default.duckdb_written_geometry_bounds)
where column_name = 'geom';

query II nosort geo_col_stats
select column_name, column_type
from iceberg_column_stats(my_datalake.default.spark_table_with_geometry_type)
where column_name = 'geom';

statement ok
drop table if exists my_datalake.default.duckdb_written_geometry_bounds;
