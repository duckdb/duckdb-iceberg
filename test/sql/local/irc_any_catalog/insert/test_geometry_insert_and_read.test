# name: test/sql/local/irc_any_catalog/insert/test_geometry_insert_and_read.test
# description: test inserting and reading geometry columns in iceberg tables
# group: [insert]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
set enable_logging=true

statement ok
set logging_level='debug'

statement ok
drop table if exists my_datalake.default.geometry_test;

# Create a table with a geometry column alongside scalar columns
statement ok
create table my_datalake.default.geometry_test (
    id INTEGER,
    name VARCHAR,
    geom GEOMETRY
) WITH ('format-version'=3);

statement ok
insert into my_datalake.default.geometry_test values
    (1, 'point_a', 'POINT (1 2)'::GEOMETRY);

mode skip

# Insert WKB-encoded geometries using ST_GeomFromWKB
# Point(1, 2): WKB little-endian = 0101000000 + x=1.0 + y=2.0
# Point(3, 4): WKB little-endian = 0101000000 + x=3.0 + y=4.0
statement ok
insert into my_datalake.default.geometry_test values
    (1, 'point_a', ST_GeomFromWKB('\x0101000000000000000000F03F0000000000000040'::BLOB)),
    (2, 'point_b', ST_GeomFromWKB('\x010100000000000000000008400000000000001040'::BLOB)),
    (3, 'null_geom', NULL);

# Verify rows are readable and geometry round-trips through WKB
query III
select id, name, ST_AsText(geom) from my_datalake.default.geometry_test order by id;
----
1	point_a	POINT (1 2)
2	point_b	POINT (3 4)
3	null_geom	NULL

# Geometry columns should have NULL upper/lower bounds in manifest stats
# (geometry has no meaningful scalar min/max; bounding box stats are not stored in Iceberg manifests)
query IIII
select column_name, column_type, upper_bound, lower_bound
from iceberg_column_stats(my_datalake.default.geometry_test)
order by column_name;
----
geom	GEOMETRY	NULL	NULL
id	INTEGER	3	1
name	VARCHAR	point_b	null_geom

# Verify null counts are tracked correctly for geometry column (1 NULL out of 3 rows)
statement ok
set variable manifest_path = (
    select manifest_path
    from iceberg_metadata(my_datalake.default.geometry_test)
    order by manifest_sequence_number desc
    limit 1
);

query II
select unnest(map_keys(null_value_counts)) col_id,
       unnest(map_values(null_value_counts)) null_count
from (select unnest(data_file) from read_avro(getvariable('manifest_path')))
order by col_id;
----
1	0
2	0
3	1

statement ok
drop table if exists my_datalake.default.geometry_test;
