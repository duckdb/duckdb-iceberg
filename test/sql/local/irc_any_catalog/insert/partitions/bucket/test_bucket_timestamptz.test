# name: test/sql/local/irc_any_catalog/insert/partitions/bucket/test_bucket_timestamptz.test
# description: Insert into a bucket-partitioned TIMESTAMPTZ table and verify round-trip
# group: [bucket]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_bucket_timestamptz;

statement ok
CREATE TABLE my_datalake.default.test_bucket_timestamptz (id int, val timestamptz)
PARTITIONED BY (bucket(val, 4));

statement ok
insert into my_datalake.default.test_bucket_timestamptz
select range, ('2020-01-01 00:00:00'::TIMESTAMP + INTERVAL (range) HOUR)::TIMESTAMPTZ from range(20);

statement ok
create table local_bucket_timestamptz as
select range as id, ('2020-01-01 00:00:00'::TIMESTAMP + INTERVAL (range) HOUR)::TIMESTAMPTZ as val from range(20);

query II nosort expected_result
select * from local_bucket_timestamptz order by id;
----

query II nosort expected_result
select * from my_datalake.default.test_bucket_timestamptz order by id;
----

query I
select count(*) from my_datalake.default.test_bucket_timestamptz;
----
20
