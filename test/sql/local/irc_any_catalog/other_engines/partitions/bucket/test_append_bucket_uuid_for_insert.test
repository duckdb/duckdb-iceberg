# name: test/sql/local/irc_any_catalog/other_engines/partitions/bucket/test_append_bucket_uuid_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a bucket(4, value)
#              UUID table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.
# group: [bucket]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted 10 UUIDs (spread across 4 buckets) plus NULL.

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert;
----
11

statement ok
set variable manifest_list_path = (select manifest_list from iceberg_snapshots(my_datalake.default.bucket_partitioned_uuid_for_insert) order by sequence_number desc limit 1);

statement ok
set variable manifest_file_path = (select manifest_path from read_avro(getvariable('manifest_list_path')) order by sequence_number desc limit 1);

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.bucket_partitioned_uuid_for_insert VALUES
    (101, '00000000-0000-0000-0000-000000000001'::UUID),
    (102, '00000000-0000-0000-0000-000000000002'::UUID),
    (103, '00000000-0000-0000-0000-000000000003'::UUID),
    (104, '00000000-0000-0000-0000-000000000004'::UUID),
    (105, '00000000-0000-0000-0000-000000000005'::UUID),
    (106, '00000000-0000-0000-0000-000000000006'::UUID),
    (107, '00000000-0000-0000-0000-000000000007'::UUID),
    (108, '00000000-0000-0000-0000-000000000008'::UUID),
    (109, '00000000-0000-0000-0000-000000000009'::UUID),
    (110, '00000000-0000-0000-0000-00000000000a'::UUID),
    (111, NULL);

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000001'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000002'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000003'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000004'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000005'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000006'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000007'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000008'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-000000000009'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value = '00000000-0000-0000-0000-00000000000a'::UUID;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_uuid_for_insert where value is null;
----
2
