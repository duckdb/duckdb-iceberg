# name: test/sql/local/irc_any_catalog/other_engines/partitions/test_append_bucket_time_for_insert.test
# description: DuckDB appends the exact same values Spark inserted into a bucket(4, value)
#              TIME table. Filtering on each value must return exactly 2 rows — one from Spark,
#              one from DuckDB — proving both ended up in the same partition.
# group: [append]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

# ---- Verify Spark's initial state ----
# Spark inserted 10 times (01:00:00 through 10:00:00, spread across 4 buckets) plus NULL.

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert;
----
11

statement ok
set variable manifest_list_path = (select manifest_list from iceberg_snapshots(my_datalake.default.bucket_partitioned_time_for_insert) order by sequence_number desc limit 1);

statement ok
set variable manifest_file_path = (select manifest_path from read_avro(getvariable('manifest_list_path')) order by sequence_number desc limit 1);

# ---- DuckDB inserts the same values Spark inserted, with new ids ----

statement ok
INSERT INTO my_datalake.default.bucket_partitioned_time_for_insert VALUES
    (101, '01:00:00'::TIME),
    (102, '02:00:00'::TIME),
    (103, '03:00:00'::TIME),
    (104, '04:00:00'::TIME),
    (105, '05:00:00'::TIME),
    (106, '06:00:00'::TIME),
    (107, '07:00:00'::TIME),
    (108, '08:00:00'::TIME),
    (109, '09:00:00'::TIME),
    (110, '10:00:00'::TIME),
    (111, NULL);

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert;
----
22

# ---- For each inserted value, exactly 2 rows should be visible ----
# One row from Spark (id 1-11) and one from DuckDB (id 101-111).

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '01:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '02:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '03:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '04:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '05:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '06:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '07:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '08:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '09:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value = '10:00:00'::TIME;
----
2

query I
select count(*) from my_datalake.default.bucket_partitioned_time_for_insert where value is null;
----
2
