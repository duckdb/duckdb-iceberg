# name: test/sql/local/null_stats.test
# group: [local]

require-env RUN_FROM_DUCKDB_BINARY

statement ok
INSTALL 'build/release/extension/parquet/parquet.duckdb_extension';

statement ok
LOAD 'build/release/extension/parquet/parquet.duckdb_extension';

statement ok
INSTALL 'build/release/extension/parquet/avro.duckdb_extension';

statement ok
LOAD 'build/release/extension/parquet/avro.duckdb_extension';

statement ok
INSTALL 'build/release/extension/parquet/iceberg.duckdb_extension';

statement ok
LOAD 'build/release/extension/parquet/iceberg.duckdb_extension';

statement ok
CREATE SECRET (
	TYPE S3,
	KEY_ID 'admin',
	SECRET 'password',
	ENDPOINT '127.0.0.1:9000',
	URL_STYLE 'path',
	USE_SSL 0
); 

statement ok
ATTACH '' AS my_datalake (
	TYPE ICEBERG,
	CLIENT_ID 'admin',
	CLIENT_SECRET 'password',
	ENDPOINT 'http://127.0.0.1:8181'
);

statement ok
create schema if not exists my_datalake.default;

statement ok
drop table if exists my_datalake.default.test_create_table_1;

statement ok
create table my_datalake.default.test_create_table_1 (a int) PARTITIONED BY (a);

statement ok
insert into my_datalake.default.test_create_table_1 select range a from range(10000);





