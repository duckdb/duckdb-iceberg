# name: test/sql/local/catalog_custom_setup/sigv4_mock/test_credential_refresh.test
# description: SigV4 credential auto-refresh is time-gated (refreshes on first use, not on every request)
# group: [sigv4_mock]

# Setup: source scripts/credential_refresh_test_setup.sh
# That starts scripts/sigv4_mock_server.py (an Iceberg REST catalog + STS mock
# that issues rotating credentials and exposes a /refresh_count endpoint) and
# exports the AWS_* env the aws extension's sts chain needs to target the mock.
require-env CREDENTIAL_REFRESH_MOCK_AVAILABLE

require avro

require parquet

require iceberg

require httpfs

require aws

require json

set ignore_error_messages

# The sts chain resolves against the mock STS (via AWS_ENDPOINT_URL_STS) and
# stores refresh_info, which is what enables SIGV4Authorization::MaybeRefreshSecret
# to refresh. (web_identity would be the production chain, but its CRT provider
# hardcodes https://sts.<region>.amazonaws.com and can't target a local mock;
# MaybeRefreshSecret is chain-agnostic, so the sts chain exercises the same path.)
statement ok
CREATE SECRET sigv4_refresh_secret (
    TYPE S3,
    PROVIDER credential_chain,
    CHAIN 'sts',
    ASSUME_ROLE_ARN 'arn:aws:iam::123456789012:role/mock-role',
    REGION 'us-east-1'
);

# Attaching issues a GET /v1/config through the SigV4 signing path. The first
# request always refreshes (initial last_refresh_time is at the epoch, so the
# 300s time-gate is satisfied).
statement ok
ATTACH 'test_warehouse' AS refresh_catalog (
    TYPE ICEBERG,
    ENDPOINT 'http://127.0.0.1:19140',
    AUTHORIZATION_TYPE 'sigv4',
    SIGV4_REGION 'us-east-1',
    SIGV4_SERVICE 'execute-api'
);

# The refresh must have fired at least once (attach + first API call).
query I
SELECT (r->>'sts_call_count')::BIGINT >= 1
FROM read_json('http://127.0.0.1:19140/refresh_count') r;
----
true

# Capture the count after the initial refresh.
statement ok
CREATE TABLE count_after_attach AS
SELECT (r->>'sts_call_count')::BIGINT AS n
FROM read_json('http://127.0.0.1:19140/refresh_count') r;

# Issue several more catalog requests in quick succession. These are all within
# the 300s refresh window, so MaybeRefreshSecret must NOT refresh again.
statement ok
SHOW ALL TABLES;

statement ok
SHOW ALL TABLES;

statement ok
SHOW ALL TABLES;

# The STS call count must be unchanged — proving the time-gate prevents a
# refresh on every request (the reviewer's concern).
query I
SELECT (r->>'sts_call_count')::BIGINT = (SELECT n FROM count_after_attach)
FROM read_json('http://127.0.0.1:19140/refresh_count') r;
----
true

statement ok
DETACH refresh_catalog;

statement ok
DROP SECRET sigv4_refresh_secret;

statement ok
DROP TABLE count_after_attach;
