# name: test/sql/local/equality_delete_extra_column.test
# description: Equality-delete on a transform-partitioned table
# group: [local]


require avro

require parquet

require iceberg

require httpfs

# id=2 is removed by an equality delete; the table is partitioned by bucket(val).
query IT
SELECT id, val FROM ICEBERG_SCAN('__WORKING_DIRECTORY__/data/persistent/equality_delete_extra_column/warehouse/ns/t/metadata/vfinal.metadata.json') ORDER BY id;
----
1	a
3	c

query I
SELECT count(*) FROM ICEBERG_SCAN('__WORKING_DIRECTORY__/data/persistent/equality_delete_extra_column/warehouse/ns/t/metadata/vfinal.metadata.json');
----
2

# projecting only a non-key column must still apply the delete
query T
SELECT val FROM ICEBERG_SCAN('__WORKING_DIRECTORY__/data/persistent/equality_delete_extra_column/warehouse/ns/t/metadata/vfinal.metadata.json') ORDER BY val;
----
a
c
