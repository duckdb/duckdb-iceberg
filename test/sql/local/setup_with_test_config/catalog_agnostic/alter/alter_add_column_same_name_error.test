# name: test/sql/local/setup_with_test_config/catalog_agnostic/alter/alter_add_column_same_name_error.test
# group: [alter]

require-env TEST_CONFIG_CATALOG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging(level='warning');

statement ok
SET warnings_as_errors = True;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
drop table if exists my_datalake.default.alter_add_column_same_txn_table;

statement ok
CREATE TABLE my_datalake.default.alter_add_column_same_txn_table AS (select range a FROM range(10));

statement error
ALTER TABLE my_datalake.default.alter_add_column_same_txn_table ADD COLUMN a int;
----
Catalog Error: Column with name a already exists!

query I
FROM my_datalake.default.alter_add_column_same_txn_table;
