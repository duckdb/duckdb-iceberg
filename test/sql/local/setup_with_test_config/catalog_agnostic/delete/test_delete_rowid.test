# name: test/sql/local/setup_with_test_config/catalog_agnostic/delete/test_delete_rowid.test
# description: test integration with iceberg catalog read
# group: [delete]

require-env TEST_CONFIG_CATALOG_SETUP

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
CALL enable_logging('HTTP');

statement ok
set logging_level='debug'

statement ok
drop table if exists my_datalake.default.test_delete_table;

statement ok
create table my_datalake.default.test_delete_table (a int);

statement ok
insert into my_datalake.default.test_delete_table select range a from range(1000);

query I
delete from my_datalake.default.test_delete_table where _row_id in (0, 2, 4, 6);
----
0
