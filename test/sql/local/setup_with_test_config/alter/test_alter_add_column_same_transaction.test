# name: test/sql/local/setup_with_test_config/alter/test_alter_add_column_same_transaction.test
# group: [alter]

require-env ICEBERG_SERVER_AVAILABLE

require-env SECRETS_CREATED_AND_CATALOG_ATTACHED

require avro

require parquet

require iceberg

require httpfs

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
drop table if exists my_datalake.default.alter_add_column_same_txn_table;

statement ok
CREATE SCHEMA IF NOT EXISTS my_datalake.default;

statement ok
CREATE TABLE my_datalake.default.alter_add_column_same_txn_table AS (select range a FROM range(10));

# ALTER and SELECT in the same explicit transaction. This exercises HasTransactionUpdates() = true path
# in IcebergTableEntry::GetScanFunction, where scan_info uses the in-memory updated_table rather than a REST fetch.
statement ok
begin;

statement ok
ALTER TABLE my_datalake.default.alter_add_column_same_txn_table ADD COLUMN b int;

query II
FROM my_datalake.default.alter_add_column_same_txn_table;
----
0	NULL
1	NULL
2	NULL
3	NULL
4	NULL
5	NULL
6	NULL
7	NULL
8	NULL
9	NULL

statement ok
commit;
